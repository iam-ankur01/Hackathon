# Backend configuration
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Groq API (for AI pipeline)
GROQ_API_KEY=your_groq_api_key_here

# Firebase Admin SDK
# Local dev: path to service account JSON file (downloaded from Firebase console)
FIREBASE_CREDENTIALS=./firebase-service-account.json
# Deploy (Render/etc.): paste full JSON as one line; takes precedence over the file path above
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Optional: bucket name (e.g. my-app.appspot.com) for resume/audio storage
FIREBASE_STORAGE_BUCKET=

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Upload dir (used as fallback when Firebase Storage bucket not configured)
UPLOAD_DIR=./uploads
