# Runtime
APP_ENV=development
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Groq AI
GROQ_API_KEY=your_groq_api_key_here

# Firebase Admin SDK
# Local development may use a service-account file outside Git.
FIREBASE_CREDENTIALS=./firebase-service-account.json
# Production: paste the complete service-account JSON as one line.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Persistence
# Local-only fallback. Production startup rejects true.
USE_LOCAL_DB=true
LOCAL_DB_PATH=./local_data.json
UPLOAD_DIR=./uploads

# Comma-separated allowed frontend origins.
FRONTEND_ORIGIN=http://localhost:5173
